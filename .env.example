# ============================================================
# SRP AI HRMS - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# ---- General ----
NODE_ENV=development
APP_NAME=SRP AI HRMS
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PREFIX=api/v1
PORT=4000

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=srp_hrms
DB_PASSWORD=your_secure_password_here
DB_DATABASE=srp_hrms
DB_SSL=false
DB_LOGGING=true
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ---- Elasticsearch ----
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elastic_password_here

# ---- MinIO (S3-Compatible Storage) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=srp_minio_access
MINIO_SECRET_KEY=your_minio_secret_here
MINIO_BUCKET=srp-hrms
MINIO_USE_SSL=false

# ---- JWT & Auth ----
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_jwt_secret_minimum_32_chars_here
JWT_REFRESH_EXPIRES_IN=7d

# ---- OAuth Providers ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:4000/api/v1/auth/microsoft/callback

# ---- AI/LLM Configuration ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# AI Engine
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=your_ai_engine_key_here

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ---- NATS (Event Bus) ----
NATS_URL=nats://localhost:4222

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="SRP AI HRMS <noreply@srpailabs.com>"

# ---- SendGrid (Alternative Email) ----
SENDGRID_API_KEY=

# ---- WhatsApp ----
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ---- LinkedIn ----
# Register at: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/v1/auth/linkedin/callback

# ---- Job Portals (Official Partner APIs Only) ----
# IMPORTANT: Direct scraping is illegal. Use official partner APIs only.
# Naukri.com: Apply at https://www.naukri.com/employers (Recruiter API)
# Monster: Apply at https://www.monster.com/hiring/products (Partner API)
NAUKRI_PARTNER_ID=
NAUKRI_API_KEY=
MONSTER_PARTNER_ID=
MONSTER_API_KEY=

# ---- n8n Automation ----
N8N_HOST=localhost
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password_here
N8N_WEBHOOK_URL=http://localhost:5678

# ---- Monitoring ----
SENTRY_DSN=
GRAFANA_URL=http://localhost:3001

# ---- Rate Limiting ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Encryption ----
ENCRYPTION_KEY=your_32_byte_encryption_key_here_

# ============================================================
# PRODUCTION OVERRIDES (set in .env.production)
# ============================================================
# APP_URL=https://app.hrms.srpailabs.com
# API_URL=https://api.hrms.srpailabs.com
# MARKETING_URL=https://hrms.srpailabs.com
# CORS_ORIGINS=https://hrms.srpailabs.com,https://app.hrms.srpailabs.com,https://api.hrms.srpailabs.com
