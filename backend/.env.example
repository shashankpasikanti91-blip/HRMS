# ============================================================
# SRP AI HRMS Backend - Environment Configuration
# ============================================================
# Copy to .env and fill in values. NEVER commit .env
# ============================================================

# ── Application ────────────────────────────────────────────
APP_NAME="SRP AI HRMS"
APP_VERSION="1.0.0"
APP_ENV=development
DEBUG=true
PORT=8080
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.hrms.srpailabs.com

# ── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://srp_hrms:your_password@localhost:5432/srp_hrms
DATABASE_SYNC_URL=postgresql://srp_hrms:your_password@localhost:5432/srp_hrms
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379/0
REDIS_CACHE_TTL=300
TOKEN_BLACKLIST_TTL=86400

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_minimum_64_chars_random_secret_key_for_production_use
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_RESET_TOKEN_EXPIRE_MINUTES=60

# ── Super Admin ────────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@srpailabs.com
SUPER_ADMIN_PASSWORD=SuperAdmin@2026!

# ── File Storage (S3 / MinIO) ─────────────────────────────
STORAGE_BACKEND=local
# Set to 's3' for AWS S3 or 'minio' for MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=srp_minio_access
S3_SECRET_ACCESS_KEY=your_minio_secret
S3_BUCKET_NAME=srp-hrms
S3_REGION=us-east-1
S3_USE_SSL=false
LOCAL_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── n8n AI Integration ────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret
N8N_CANDIDATE_SCREENING_WEBHOOK=/webhook/candidate-screening
N8N_HR_ASSISTANT_WEBHOOK=/webhook/hr-assistant
N8N_ONBOARDING_WEBHOOK=/webhook/employee-onboarding
N8N_ATTENDANCE_ALERT_WEBHOOK=/webhook/attendance-alert
N8N_TIMEOUT_SECONDS=30
N8N_ENABLED=true

# ── Google OAuth ──────────────────────────────────────────
# Get credentials from console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://api.hrms.srpailabs.com/api/v1/auth/google/callback

# ── NextAuth Internal Secret (shared with web app) ────────
# Must match NEXTAUTH_SECRET in .env.local / web container env
NEXTAUTH_SECRET=CHANGE_ME_minimum_32_chars_random_secret_for_nextauth

# ── Owner Notifications ────────────────────────────────────
# Telegram: create bot with @BotFather, then get chat_id via
#   https://api.telegram.org/bot<TOKEN>/getUpdates (send /start first)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_OWNER_CHAT_ID=your_telegram_chat_id_here
# Email you want to receive all signup / alert notifications
OWNER_NOTIFICATION_EMAIL=pasikantishashank24@gmail.com

# ── Email ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@srpailabs.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME="SRP AI HRMS"
SMTP_TLS=true

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:your_redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_password@localhost:6379/2

# ── OpenAPI ───────────────────────────────────────────────
OPENAPI_TITLE="SRP AI HRMS API"
OPENAPI_DESCRIPTION="Production-ready multi-tenant HRMS backend with AI integration"
OPENAPI_VERSION="1.0.0"
DOCS_ENABLED=true
