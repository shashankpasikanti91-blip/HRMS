// ============================================================
// SRP AI HRMS - Prisma Schema
// The complete database schema for the HRMS platform
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), pgcrypto, vector, pg_trgm]
}

// ============================================================
// TENANT & AUTH MODELS
// ============================================================

model Tenant {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  domain      String?  @unique @db.VarChar(255)
  logo        String?  @db.Text
  settings    Json     @default("{}")
  status      String   @default("active") @db.VarChar(20)
  plan        String   @default("starter") @db.VarChar(50)
  maxUsers    Int      @default(50) @map("max_users")
  trialEndsAt DateTime? @map("trial_ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  users         User[]
  employees     Employee[]
  departments   Department[]
  positions     Position[]
  roles         Role[]
  leaveTypes    LeaveType[]
  holidays      Holiday[]
  payrollRuns   PayrollRun[]
  jobPostings   JobPosting[]
  reviewCycles  ReviewCycle[]
  announcements Announcement[]
  documents     Document[]
  auditLogs     AuditLog[]
  chatSessions  ChatSession[]

  @@map("tenants")
}

model User {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  email          String    @db.VarChar(255)
  passwordHash   String?   @map("password_hash") @db.Text
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  avatar         String?   @db.Text
  status         String    @default("active") @db.VarChar(20)
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret") @db.Text
  googleId       String?   @map("google_id") @db.VarChar(255)
  microsoftId    String?   @map("microsoft_id") @db.VarChar(255)
  emailVerified  Boolean   @default(false) @map("email_verified")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip") @db.VarChar(45)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee?
  userRoles       UserRole[]
  refreshTokens   RefreshToken[]
  notifications   Notification[]
  auditLogs       AuditLog[]        @relation("AuditLogUser")
  chatSessions    ChatSession[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  userRoles   UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  resource String @db.VarChar(100)
  action   String @db.VarChar(50)
  description String? @db.Text

  // Relations
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleId       String  @map("role_id") @db.Uuid
  permissionId String  @map("permission_id") @db.Uuid
  conditions   Json?   // ABAC conditions

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.Text
  userAgent String?  @map("user_agent") @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================================
// CORE HR MODELS
// ============================================================

model Employee {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  employeeCode        String    @map("employee_code") @db.VarChar(50)
  firstName           String    @map("first_name") @db.VarChar(100)
  lastName            String    @map("last_name") @db.VarChar(100)
  middleName          String?   @map("middle_name") @db.VarChar(100)
  email               String    @db.VarChar(255)
  personalEmail       String?   @map("personal_email") @db.VarChar(255)
  phone               String    @db.VarChar(20)
  dateOfBirth         DateTime  @map("date_of_birth") @db.Date
  gender              String    @db.VarChar(20)
  maritalStatus       String?   @map("marital_status") @db.VarChar(20)
  nationality         String?   @db.VarChar(100)
  bloodGroup          String?   @map("blood_group") @db.VarChar(5)
  address             Json      @default("{}")
  emergencyContacts   Json      @default("[]") @map("emergency_contacts")
  departmentId        String    @map("department_id") @db.Uuid
  positionId          String    @map("position_id") @db.Uuid
  managerId           String?   @map("manager_id") @db.Uuid
  employmentType      String    @default("full_time") @map("employment_type") @db.VarChar(20)
  dateOfJoining       DateTime  @map("date_of_joining") @db.Date
  dateOfConfirmation  DateTime? @map("date_of_confirmation") @db.Date
  dateOfSeparation    DateTime? @map("date_of_separation") @db.Date
  probationEndDate    DateTime? @map("probation_end_date") @db.Date
  noticePeriod        Int       @default(30) @map("notice_period")
  status              String    @default("active") @db.VarChar(20)
  bankDetails         Json?     @map("bank_details")
  taxInfo             Json?     @map("tax_info")
  customFields        Json      @default("{}") @map("custom_fields")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  department          Department         @relation(fields: [departmentId], references: [id])
  position            Position           @relation(fields: [positionId], references: [id])
  manager             Employee?          @relation("ManagerReports", fields: [managerId], references: [id])
  directReports       Employee[]         @relation("ManagerReports")
  attendanceRecords   AttendanceRecord[]
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  salaryStructure     SalaryStructure?
  payslips            Payslip[]
  goals               Goal[]
  reviewsReceived     PerformanceReview[] @relation("ReviewEmployee")
  reviewsGiven        PerformanceReview[] @relation("ReviewReviewer")
  documents           Document[]         @relation("EmployeeDocuments")
  skills              EmployeeSkill[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([departmentId])
  @@index([managerId])
  @@index([status])
  @@map("employees")
}

model Department {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(255)
  code         String   @db.VarChar(50)
  description  String?  @db.Text
  parentId     String?  @map("parent_id") @db.Uuid
  headId       String?  @map("head_id") @db.Uuid
  costCenterId String?  @map("cost_center_id") @db.VarChar(50)
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  employees   Employee[]
  positions   Position[]
  jobPostings JobPosting[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@map("departments")
}

model Position {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  title        String   @db.VarChar(255)
  code         String   @db.VarChar(50)
  departmentId String   @map("department_id") @db.Uuid
  grade        String?  @db.VarChar(20)
  band         String?  @db.VarChar(20)
  minSalary    Decimal? @map("min_salary") @db.Decimal(12, 2)
  maxSalary    Decimal? @map("max_salary") @db.Decimal(12, 2)
  currency     String?  @default("USD") @db.VarChar(3)
  description  String?  @db.Text
  requirements Json     @default("[]")
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("positions")
}

// ============================================================
// ATTENDANCE & LEAVE MODELS
// ============================================================

model AttendanceRecord {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  date          DateTime  @db.Date
  clockIn       DateTime? @map("clock_in")
  clockOut      DateTime? @map("clock_out")
  totalHours    Decimal?  @map("total_hours") @db.Decimal(5, 2)
  overtimeHours Decimal?  @map("overtime_hours") @db.Decimal(5, 2)
  breakMinutes  Int?      @map("break_minutes")
  status        String    @default("present") @db.VarChar(20)
  source        String    @default("web") @db.VarChar(20)
  locationIn    Json?     @map("location_in")
  locationOut   Json?     @map("location_out")
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([tenantId])
  @@index([employeeId, date])
  @@index([tenantId, date])
  @@map("attendance_records")
}

model LeaveType {
  id                 String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId           String  @map("tenant_id") @db.Uuid
  name               String  @db.VarChar(100)
  code               String  @db.VarChar(20)
  description        String? @db.Text
  annualQuota        Int     @default(0) @map("annual_quota")
  carryForwardLimit  Int     @default(0) @map("carry_forward_limit")
  encashable         Boolean @default(false)
  requiresApproval   Boolean @default(true) @map("requires_approval")
  requiresAttachment Boolean @default(false) @map("requires_attachment")
  isPaid             Boolean @default(true) @map("is_paid")
  applicableGenders  Json    @default("[]") @map("applicable_genders")
  status             String  @default("active") @db.VarChar(20)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("leave_types")
}

model LeaveRequest {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  employeeId      String    @map("employee_id") @db.Uuid
  leaveTypeId     String    @map("leave_type_id") @db.Uuid
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime  @map("end_date") @db.Date
  totalDays       Decimal   @map("total_days") @db.Decimal(4, 1)
  reason          String    @db.Text
  status          String    @default("pending") @db.VarChar(20)
  approverId      String?   @map("approver_id") @db.Uuid
  approverComment String?   @map("approver_comment") @db.Text
  approvedAt      DateTime? @map("approved_at")
  attachments     Json      @default("[]")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@index([tenantId, status])
  @@map("leave_requests")
}

model LeaveBalance {
  id             String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid
  employeeId     String @map("employee_id") @db.Uuid
  leaveTypeId    String @map("leave_type_id") @db.Uuid
  year           Int
  totalQuota     Decimal @map("total_quota") @db.Decimal(5, 1)
  used           Decimal @default(0) @db.Decimal(5, 1)
  pending        Decimal @default(0) @db.Decimal(5, 1)
  carryForwarded Decimal @default(0) @map("carry_forwarded") @db.Decimal(5, 1)
  available      Decimal @default(0) @db.Decimal(5, 1)
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@index([tenantId])
  @@map("leave_balances")
}

model Holiday {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  date      DateTime @db.Date
  type      String   @default("public") @db.VarChar(20) // public, optional, restricted
  location  String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
  @@map("holidays")
}

// ============================================================
// PAYROLL MODELS
// ============================================================

model SalaryStructure {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  employeeId   String   @unique @map("employee_id") @db.Uuid
  basic        Decimal  @db.Decimal(12, 2)
  components   Json     @default("[]") // array of {name, type, value, taxable}
  grossSalary  Decimal  @map("gross_salary") @db.Decimal(12, 2)
  currency     String   @default("USD") @db.VarChar(3)
  effectiveDate DateTime @map("effective_date") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("salary_structures")
}

model PayrollRun {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  period         String    @db.VarChar(7) // YYYY-MM
  runDate        DateTime  @map("run_date")
  status         String    @default("draft") @db.VarChar(20)
  totalEmployees Int       @default(0) @map("total_employees")
  totalGross     Decimal   @default(0) @map("total_gross") @db.Decimal(14, 2)
  totalDeductions Decimal  @default(0) @map("total_deductions") @db.Decimal(14, 2)
  totalNet       Decimal   @default(0) @map("total_net") @db.Decimal(14, 2)
  currency       String    @default("USD") @db.VarChar(3)
  processedBy    String    @map("processed_by") @db.Uuid
  approvedBy     String?   @map("approved_by") @db.Uuid
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips Payslip[]

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("payroll_runs")
}

model Payslip {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  payrollRunId   String   @map("payroll_run_id") @db.Uuid
  period         String   @db.VarChar(7)
  earnings       Json     @default("[]")
  deductions     Json     @default("[]")
  grossPay       Decimal  @map("gross_pay") @db.Decimal(12, 2)
  totalDeductions Decimal @map("total_deductions") @db.Decimal(12, 2)
  netPay         Decimal  @map("net_pay") @db.Decimal(12, 2)
  currency       String   @default("USD") @db.VarChar(3)
  bankDetails    Json?    @map("bank_details")
  status         String   @default("draft") @db.VarChar(20)
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime @default(now()) @map("created_at")

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([employeeId, payrollRunId])
  @@index([tenantId])
  @@index([employeeId])
  @@map("payslips")
}

// ============================================================
// RECRUITMENT MODELS
// ============================================================

model JobPosting {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  title               String    @db.VarChar(255)
  code                String    @db.VarChar(50)
  departmentId        String    @map("department_id") @db.Uuid
  description         String    @db.Text
  requirements        Json      @default("[]")
  niceToHave          Json      @default("[]") @map("nice_to_have")
  employmentType      String    @default("full_time") @map("employment_type") @db.VarChar(20)
  experienceLevel     String    @map("experience_level") @db.VarChar(20)
  salaryMin           Decimal?  @map("salary_min") @db.Decimal(12, 2)
  salaryMax           Decimal?  @map("salary_max") @db.Decimal(12, 2)
  salaryCurrency      String?   @map("salary_currency") @db.VarChar(3)
  location            String    @db.VarChar(255)
  remotePolicy        String    @default("onsite") @map("remote_policy") @db.VarChar(20)
  vacancies           Int       @default(1)
  hiringManagerId     String    @map("hiring_manager_id") @db.Uuid
  recruiterId         String?   @map("recruiter_id") @db.Uuid
  status              String    @default("draft") @db.VarChar(20)
  publishedChannels   Json      @default("[]") @map("published_channels")
  applicationDeadline DateTime? @map("application_deadline")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department  @relation(fields: [departmentId], references: [id])
  candidates Candidate[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@map("job_postings")
}

model Candidate {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  jobId        String    @map("job_id") @db.Uuid
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  email        String    @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  resumeUrl    String?   @map("resume_url") @db.Text
  linkedinUrl  String?   @map("linkedin_url") @db.Text
  portfolioUrl String?   @map("portfolio_url") @db.Text
  source       String    @default("career_page") @db.VarChar(20)
  stage        String    @default("applied") @db.VarChar(20)
  status       String    @default("active") @db.VarChar(20)
  aiScore      Decimal?  @map("ai_score") @db.Decimal(5, 2)
  aiAnalysis   Json?     @map("ai_analysis")
  notes        String?   @db.Text
  tags         Json      @default("[]")
  appliedAt    DateTime  @default(now()) @map("applied_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  job        JobPosting  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interviews Interview[]

  @@index([tenantId])
  @@index([jobId])
  @@index([stage])
  @@index([email])
  @@map("candidates")
}

model Interview {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  candidateId  String    @map("candidate_id") @db.Uuid
  type         String    @db.VarChar(50) // phone_screen, technical, behavioral, final
  scheduledAt  DateTime  @map("scheduled_at")
  duration     Int       @default(60) // minutes
  interviewers Json      @default("[]") // array of user IDs
  location     String?   @db.VarChar(255) // room or video link
  status       String    @default("scheduled") @db.VarChar(20)
  feedback     Json?     // structured feedback
  overallRating Decimal? @map("overall_rating") @db.Decimal(3, 1)
  notes        String?   @db.Text
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([candidateId])
  @@map("interviews")
}

// ============================================================
// PERFORMANCE MODELS
// ============================================================

model ReviewCycle {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  type      String   @db.VarChar(50) // annual, semi_annual, quarterly
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  status    String   @default("draft") @db.VarChar(20)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reviews PerformanceReview[]

  @@index([tenantId])
  @@map("review_cycles")
}

model Goal {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  type        String   @default("objective") @db.VarChar(20)
  parentGoalId String? @map("parent_goal_id") @db.Uuid
  metricType  String   @default("percentage") @map("metric_type") @db.VarChar(20)
  targetValue Decimal  @map("target_value") @db.Decimal(10, 2)
  currentValue Decimal @default(0) @map("current_value") @db.Decimal(10, 2)
  weight      Decimal  @default(1) @db.Decimal(3, 2)
  startDate   DateTime @map("start_date") @db.Date
  dueDate     DateTime @map("due_date") @db.Date
  status      String   @default("not_started") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  parentGoal Goal?    @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  childGoals Goal[]   @relation("GoalHierarchy")

  @@index([tenantId])
  @@index([employeeId])
  @@map("goals")
}

model PerformanceReview {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  reviewCycleId String    @map("review_cycle_id") @db.Uuid
  reviewerId    String    @map("reviewer_id") @db.Uuid
  type          String    @db.VarChar(20) // self, manager, peer, direct_report
  overallRating Decimal?  @map("overall_rating") @db.Decimal(3, 1)
  ratings       Json      @default("[]")
  strengths     String?   @db.Text
  improvements  String?   @db.Text
  comments      String?   @db.Text
  biasFlags     Json      @default("[]") @map("bias_flags")
  status        String    @default("draft") @db.VarChar(20)
  submittedAt   DateTime? @map("submitted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  employee    Employee    @relation("ReviewEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer    Employee    @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  reviewCycle ReviewCycle @relation(fields: [reviewCycleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([reviewCycleId])
  @@map("performance_reviews")
}

// ============================================================
// SKILLS & COMPETENCY MODELS
// ============================================================

model Skill {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(255)
  category    String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  employeeSkills EmployeeSkill[]

  @@index([category])
  @@map("skills")
}

model EmployeeSkill {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId      String   @map("employee_id") @db.Uuid
  skillId         String   @map("skill_id") @db.Uuid
  proficiencyLevel Int     @default(1) @map("proficiency_level") // 1-5
  selfAssessed    Boolean  @default(true) @map("self_assessed")
  verifiedBy      String?  @map("verified_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id])

  @@unique([employeeId, skillId])
  @@map("employee_skills")
}

// ============================================================
// NOTIFICATION & COMMUNICATION MODELS
// ============================================================

model Notification {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(50)
  channel   String    @default("in_app") @db.VarChar(20)
  title     String    @db.VarChar(255)
  message   String    @db.Text
  data      Json?
  read      Boolean   @default(false)
  readAt    DateTime? @map("read_at")
  sentAt    DateTime  @default(now()) @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, read])
  @@index([tenantId, userId])
  @@map("notifications")
}

model Announcement {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  title        String    @db.VarChar(255)
  content      String    @db.Text
  type         String    @default("general") @db.VarChar(50)
  priority     String    @default("normal") @db.VarChar(20)
  targetRoles  Json      @default("[]") @map("target_roles")
  targetDepts  Json      @default("[]") @map("target_depts")
  publishedAt  DateTime? @map("published_at")
  expiresAt    DateTime? @map("expires_at")
  authorId     String    @map("author_id") @db.Uuid
  status       String    @default("draft") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("announcements")
}

// ============================================================
// DOCUMENT MODELS
// ============================================================

model Document {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  employeeId  String?   @map("employee_id") @db.Uuid
  name        String    @db.VarChar(255)
  type        String    @db.VarChar(50)
  category    String?   @db.VarChar(100)
  url         String    @db.Text
  mimeType    String    @map("mime_type") @db.VarChar(100)
  size        Int       // bytes
  expiryDate  DateTime? @map("expiry_date") @db.Date
  metadata    Json      @default("{}")
  uploadedBy  String    @map("uploaded_by") @db.Uuid
  status      String    @default("active") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee? @relation("EmployeeDocuments", fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([type])
  @@map("documents")
}

// ============================================================
// AI & CHATBOT MODELS
// ============================================================

model ChatSession {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?  @db.VarChar(255)
  status    String   @default("active") @db.VarChar(20)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([tenantId])
  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String   @db.VarChar(20) // user, assistant, system
  content   String   @db.Text
  metadata  Json     @default("{}") // sources, confidence, model, tokens
  createdAt DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model DocumentEmbedding {
  id        String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String                     @map("tenant_id") @db.Uuid
  documentId String?                   @map("document_id") @db.Uuid
  content   String                     @db.Text
  embedding Unsupported("vector(1536)")
  metadata  Json                       @default("{}")
  createdAt DateTime                   @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("document_embeddings")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?  @map("resource_id") @db.Uuid
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation("AuditLogUser", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
